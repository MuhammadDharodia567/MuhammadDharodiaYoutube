# BIRRA AI - Environment Configuration

# Anthropic Claude API (for script optimization)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs API (optional, for high-quality voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Server Configuration
PORT=4000
NODE_ENV=development

# Optional: Google Cloud TTS (alternative voice option)
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Optional: Cloud Storage for videos
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your-bucket-name
